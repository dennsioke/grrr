+++ b/src/helpers/resolveKeyframeStyles.ts
@@ -0,0 +1,306 @@
+import bezier from 'bezier-easing';
+import { parseValueAndUnit } from 'parallax-controller';
+import {
+  ParallaxKeyframe,
+  EffectName,
+  EffectBounds,
+  InterpolatedEffectValues,
+  EFFECT_NAMES,
+  TRANSFORM_EFFECT_NAMES,
+  EFFECT_DEFAULT_UNITS,
+  EFFECT_IDENTITY_VALUES,
+} from '../types/keyframes';
+interface ParsedStop {
+  progress: number;
+  easingFn?: (t: number) => number;
+  values: Map<EffectName, { value: number; unit: string }>;
+}
+const CONFLICT_PROPS: string[] = ['speed', ...EFFECT_NAMES];
+export function stripEffectProps(
+  props: Record<string, any>
+): Record<string, any> {
+  const cleaned: Record<string, any> = {};
+  for (const key of Object.keys(props)) {
+    if (!(EFFECT_NAMES as readonly string[]).includes(key) && key !== 'speed') {
+      cleaned[key] = props[key];
+    }
+  }
+  return cleaned;
+}
+function validateEasingTuple(easing: number[], stopIndex: number): void {
+  if (easing.length !== 4) {
+    throw new Error(
+      `Keyframe at index ${stopIndex} has an easing with ${easing.length} values; expected exactly 4.`
+    );
+  }
+  for (let i = 0; i < 4; i++) {
+    if (typeof easing[i] !== 'number' || !Number.isFinite(easing[i])) {
+      throw new Error(
+        `Keyframe at index ${stopIndex} has a non-finite easing value at position ${i}.`
+      );
+    }
+  }
+  if (easing[0] < 0 || easing[0] > 1) {
+    throw new Error(
+      `Keyframe at index ${stopIndex} has easing x1=${easing[0]} outside [0,1].`
+    );
+  }
+  if (easing[2] < 0 || easing[2] > 1) {
+    throw new Error(
+      `Keyframe at index ${stopIndex} has easing x2=${easing[2]} outside [0,1].`
+    );
+  }
+}
+function validateStopEffects(kf: ParallaxKeyframe, index: number): void {
+  if (typeof kf.progress !== 'number' || !Number.isFinite(kf.progress)) {
+    throw new Error(
+      `Keyframe at index ${index} has a non-finite progress value.`
+    );
+  }
+  if (kf.progress < 0 || kf.progress > 1) {
+    throw new Error(
+      `Keyframe at index ${index} has progress=${kf.progress} outside [0,1].`
+    );
+  }
+  for (const name of EFFECT_NAMES) {
+    const raw = kf[name];
+    if (raw === undefined) continue;
+    if (typeof raw === 'number' && !Number.isFinite(raw)) {
+      throw new Error(
+        `Keyframe at index ${index} has a non-finite value for ${name}.`
+      );
+    }
+  }
+}
+function checkUnitConsistency(keyframes: ParallaxKeyframe[]): void {
+  const effectUnits = new Map<EffectName, string>();
+  for (let i = 0; i < keyframes.length; i++) {
+    const kf = keyframes[i];
+    for (const name of EFFECT_NAMES) {
+      const raw = kf[name];
+      if (raw === undefined) continue;
+      const defaultUnit = EFFECT_DEFAULT_UNITS[name];
+      const parsed = parseValueAndUnit(raw, defaultUnit);
+      const existing = effectUnits.get(name);
+      if (existing !== undefined && existing !== parsed.unit) {
+        throw new Error(
+          `Keyframe at index ${i} uses unit '${parsed.unit}' for ${name}, but a previous stop used '${existing}'. Units must be consistent across stops.`
+        );
+      }
+      effectUnits.set(name, parsed.unit);
+    }
+  }
+}
+export function validateKeyframes(
+  keyframes: ParallaxKeyframe[],
+  props: Record<string, any>
+): void {
+  if (!keyframes || keyframes.length === 0) return;
+  for (const conflictProp of CONFLICT_PROPS) {
+    if (props[conflictProp] !== undefined) {
+      throw new Error(
+        `Cannot use keyframes with ${conflictProp}. Keyframes are mutually exclusive with individual effect props and speed.`
+      );
+    }
+  }
+  for (let i = 0; i < keyframes.length; i++) {
+    validateStopEffects(keyframes[i], i);
+    if (keyframes[i].easing && i > 0) {
+      validateEasingTuple(keyframes[i].easing as number[], i);
+    }
+  }
+  if (keyframes[0].easing) {
+    throw new Error(
+      'The first keyframe (progress=0) must not have an easing; easing applies to the preceding segment.'
+    );
+  }
+  if (keyframes[0].progress !== 0) {
+    throw new Error('Keyframes must include a stop at progress 0.');
+  }
+  if (keyframes[keyframes.length - 1].progress !== 1) {
+    throw new Error('Keyframes must include a stop at progress 1.');
+  }
+  for (let i = 1; i < keyframes.length; i++) {
+    if (keyframes[i].progress <= keyframes[i - 1].progress) {
+      throw new Error(
+        'Keyframes must be sorted by ascending progress values.'
+      );
+    }
+  }
+  checkUnitConsistency(keyframes);
+}
+function propagateEffects(stops: ParsedStop[]): void {
+  const lastKnown = new Map<EffectName, { value: number; unit: string }>();
+  const allEffects = new Set<EffectName>();
+  for (const stop of stops) {
+    for (const name of stop.values.keys()) {
+      allEffects.add(name);
+    }
+  }
+  for (const stop of stops) {
+    for (const name of allEffects) {
+      if (stop.values.has(name)) {
+        lastKnown.set(name, stop.values.get(name)!);
+      } else if (lastKnown.has(name)) {
+        stop.values.set(name, lastKnown.get(name)!);
+      }
+    }
+  }
+}
+function parseStops(keyframes: ParallaxKeyframe[]): ParsedStop[] {
+  const stops = keyframes.map((kf) => {
+    const values = new Map<EffectName, { value: number; unit: string }>();
+    for (const name of EFFECT_NAMES) {
+      const raw = kf[name];
+      if (raw === undefined) continue;
+      const defaultUnit = EFFECT_DEFAULT_UNITS[name];
+      const parsed = parseValueAndUnit(raw, defaultUnit);
+      values.set(name, { value: parsed.value, unit: parsed.unit });
+    }
+    let easingFn: ((t: number) => number) | undefined;
+    if (kf.easing) {
+      easingFn = bezier(kf.easing[0], kf.easing[1], kf.easing[2], kf.easing[3]);
+    }
+    return { progress: kf.progress, easingFn, values };
+  });
+  propagateEffects(stops);
+  return stops;
+}
+function findSegment(
+  stops: ParsedStop[],
+  progress: number
+): { start: ParsedStop; end: ParsedStop } {
+  if (progress <= 0) return { start: stops[0], end: stops[0] };
+  if (progress >= 1) {
+    const last = stops[stops.length - 1];
+    return { start: last, end: last };
+  }
+  for (let i = 1; i < stops.length; i++) {
+    if (progress <= stops[i].progress) {
+      return { start: stops[i - 1], end: stops[i] };
+    }
+  }
+  const last = stops[stops.length - 1];
+  return { start: last, end: last };
+}
+function interpolateValue(
+  startVal: number,
+  endVal: number,
+  localProgress: number
+): number {
+  return startVal + (endVal - startVal) * localProgress;
+}
+function clampProgress(progress: number): number {
+  if (progress < 0) return 0;
+  if (progress > 1) return 1;
+  return progress;
+}
+function computeLocalProgress(
+  start: ParsedStop,
+  end: ParsedStop,
+  progress: number
+): number {
+  const segmentWidth = end.progress - start.progress;
+  let local: number;
+  if (segmentWidth === 0) {
+    local = 0;
+  } else {
+    local = (progress - start.progress) / segmentWidth;
+  }
+  if (end.easingFn) {
+    local = end.easingFn(local);
+  }
+  return local;
+}
+export function interpolateEffectsAtProgress(
+  keyframes: ParallaxKeyframe[],
+  progress: number
+): InterpolatedEffectValues {
+  const clamped = clampProgress(progress);
+  const stops = parseStops(keyframes);
+  const { start, end } = findSegment(stops, clamped);
+  const local = computeLocalProgress(start, end, clamped);
+  const result: Record<string, number> = {};
+  for (const name of EFFECT_NAMES) {
+    const startParsed = start.values.get(name);
+    const endParsed = end.values.get(name);
+    if (!startParsed && !endParsed) {
+      result[name] = EFFECT_IDENTITY_VALUES[name];
+      continue;
+    }
+    const sv = startParsed ? startParsed.value : 0;
+    const ev = endParsed ? endParsed.value : 0;
+    result[name] = interpolateValue(sv, ev, local);
+  }
+  return result as unknown as InterpolatedEffectValues;
+}
+export function resolveKeyframeStyles(
+  keyframes: ParallaxKeyframe[],
+  progress: number
+): { transform: string; opacity: string } {
+  const clamped = clampProgress(progress);
+  const stops = parseStops(keyframes);
+  const { start, end } = findSegment(stops, clamped);
+  const local = computeLocalProgress(start, end, clamped);
+  let transformStr = '';
+  let opacityStr = '';
+  for (const name of TRANSFORM_EFFECT_NAMES) {
+    const startParsed = start.values.get(name);
+    const endParsed = end.values.get(name);
+    if (!startParsed && !endParsed) continue;
+    const sv = startParsed ? startParsed.value : 0;
+    const ev = endParsed ? endParsed.value : 0;
+    const unit = startParsed?.unit ?? endParsed?.unit ?? EFFECT_DEFAULT_UNITS[name];
+    const interpolated = interpolateValue(sv, ev, local);
+    if (transformStr) transformStr += ' ';
+    transformStr += `${name}(${interpolated}${unit})`;
+  }
+  const startOpacity = start.values.get('opacity');
+  const endOpacity = end.values.get('opacity');
+  if (startOpacity || endOpacity) {
+    const sv = startOpacity ? startOpacity.value : 0;
+    const ev = endOpacity ? endOpacity.value : 0;
+    const interpolated = interpolateValue(sv, ev, local);
+    opacityStr = `${interpolated}`;
+  }
+  return { transform: transformStr, opacity: opacityStr };
+}
+export function applyKeyframeStylesToElement(
+  el: HTMLElement,
+  keyframes: ParallaxKeyframe[],
+  progress: number
+): void {
+  const { transform, opacity } = resolveKeyframeStyles(keyframes, progress);
+  el.style.transform = transform;
+  el.style.opacity = opacity;
+}
+export function getKeyframeEffectBounds(
+  keyframes: ParallaxKeyframe[],
+  effectName: EffectName
+): EffectBounds {
+  let min = Infinity;
+  let max = -Infinity;
+  let unit = EFFECT_DEFAULT_UNITS[effectName];
+  for (const kf of keyframes) {
+    const raw = kf[effectName];
+    if (raw === undefined) continue;
+    const defaultUnit = EFFECT_DEFAULT_UNITS[effectName];
+    const parsed = parseValueAndUnit(raw, defaultUnit);
+    unit = parsed.unit;
+    if (parsed.value < min) min = parsed.value;
+    if (parsed.value > max) max = parsed.value;
+  }
+  if (min === Infinity) {
+    min = 0;
+    max = 0;
+  }
+  return { min, max, unit };
+}
+export function getKeyframeMaxTranslateY(
+  keyframes: ParallaxKeyframe[]
+): { maxPositive: number; maxNegative: number; unit: string } {
+  const bounds = getKeyframeEffectBounds(keyframes, 'translateY');
+  const maxPositive = bounds.max > 0 ? bounds.max : 0;
+  const maxNegative = bounds.min < 0 ? Math.abs(bounds.min) : 0;
+  return { maxPositive, maxNegative, unit: bounds.unit };
+}
