@@ -0,0 +1,88 @@
+import { EasingParams } from 'parallax-controller';
+export interface KeyframeEffectValues {
+  translateX?: number | string;
+  translateY?: number | string;
+  rotate?: number | string;
+  rotateX?: number | string;
+  rotateY?: number | string;
+  rotateZ?: number | string;
+  scale?: number;
+  scaleX?: number;
+  scaleY?: number;
+  scaleZ?: number;
+  opacity?: number;
+}
+export interface ParallaxKeyframe extends KeyframeEffectValues {
+  progress: number;
+  easing?: EasingParams;
+}
+export interface KeyframeConfig {
+  keyframes?: ParallaxKeyframe[];
+}
+export interface InterpolatedEffectValues {
+  translateX: number;
+  translateY: number;
+  rotate: number;
+  rotateX: number;
+  rotateY: number;
+  rotateZ: number;
+  scale: number;
+  scaleX: number;
+  scaleY: number;
+  scaleZ: number;
+  opacity: number;
+}
+export interface EffectBounds {
+  min: number;
+  max: number;
+  unit: string;
+}
+export const EFFECT_NAMES = [
+  'translateX',
+  'translateY',
+  'rotate',
+  'rotateX',
+  'rotateY',
+  'rotateZ',
+  'scale',
+  'scaleX',
+  'scaleY',
+  'scaleZ',
+  'opacity',
+] as const;
+export type EffectName = (typeof EFFECT_NAMES)[number];
+export const TRANSFORM_EFFECT_NAMES = EFFECT_NAMES.filter(
+  (n) => n !== 'opacity'
+);
+export const SCALE_EFFECT_NAMES: readonly EffectName[] = [
+  'scale',
+  'scaleX',
+  'scaleY',
+  'scaleZ',
+];
+export const EFFECT_DEFAULT_UNITS: Record<EffectName, string> = {
+  translateX: '%',
+  translateY: '%',
+  rotate: 'deg',
+  rotateX: 'deg',
+  rotateY: 'deg',
+  rotateZ: 'deg',
+  scale: '',
+  scaleX: '',
+  scaleY: '',
+  scaleZ: '',
+  opacity: '',
+};
+export const EFFECT_IDENTITY_VALUES: Record<EffectName, number> = {
+  translateX: 0,
+  translateY: 0,
+  rotate: 0,
+  rotateX: 0,
+  rotateY: 0,
+  rotateZ: 0,
+  scale: 1,
+  scaleX: 1,
+  scaleY: 1,
+  scaleZ: 1,
+  opacity: 1,
+};
