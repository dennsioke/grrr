+#!/usr/bin/env bash
+set -uo pipefail
+
+export NODE_ENV=test
+
+OUTPUT_PATH=""
+MODE=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="$2"
+      shift 2
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Usage: $0 --output_path <path> [base|new]" >&2
+      exit 1
+      ;;
+  esac
+done
+
+if [[ -z "$MODE" ]]; then
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
+
+if [[ -z "$OUTPUT_PATH" ]]; then
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
+
+EXIT_CODE=0
+if [[ "$MODE" == "base" ]]; then
+  npx vitest run --reporter=junit --outputFile="$OUTPUT_PATH" src/components/Parallax/index.test.tsx src/components/ParallaxBanner/index.test.tsx src/components/ParallaxBanner/helpers/getExpandedStyle.test.ts src/components/ParallaxProvider/index.test.tsx src/hooks/useParallax.test.tsx src/hooks/useParallaxController.test.tsx
+  EXIT_CODE=$?
+elif [[ "$MODE" == "new" ]]; then
+  npx vitest run --reporter=junit --outputFile="$OUTPUT_PATH" src/keyframes.test.tsx
+  EXIT_CODE=$?
+fi
+
+if [ ! -f "$OUTPUT_PATH" ]; then
+  cat > "$OUTPUT_PATH" <<'EOF'
+<?xml version="1.0" encoding="UTF-8"?>
+<testsuites name="vitest" tests="0" failures="1" errors="1" time="0">
+  <testsuite name="keyframes" tests="0" failures="1" errors="1" time="0">
+    <testcase name="vitest-run-failed" classname="keyframes">
+      <failure message="Vitest failed to produce output">Vitest process failed to produce JUnit XML output</failure>
+    </testcase>
+  </testsuite>
+</testsuites>
+EOF
+fi
+
+exit "$EXIT_CODE"
